{%- comment -%}
  ============================================================================
  Gift Guide — Banner  (custom section, built from scratch)
  ----------------------------------------------------------------------------
  Renders the top hero of the Gift Guide page:
    - utility bar   : logo text + tagline + "CHOOSE GIFT" button
    - hero          : background illustration, heading, description, "SHOP NOW"
    - footer bar    : sustainability strip

  Every piece of copy highlighted in the Figma is exposed through the schema
  below so a merchant can edit it from the Theme Editor without touching code.

  PHASE STATUS
    [x] Phase 1  scaffold + schema
    [x] Phase 2  desktop markup, pixel-perfect @1440 (this file, current)
    [ ] Phase 3  responsive @375 + button animation
  ============================================================================
{%- endcomment -%}

{{ 'gift-guide.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings
  # Reusable long-arrow used by both buttons.
  capture arrow
    echo '<svg class="gg-arrow" viewBox="0 0 42 14" fill="none" aria-hidden="true" focusable="false"><path d="M0 7h39M33 1l7 6-7 6" stroke="currentColor" stroke-width="1.4"/></svg>'
  endcapture
-%}

<section class="gg-banner" data-gift-guide-banner>
  {%- comment -%} Utility bar: logo, tagline, "choose gift" button. {%- endcomment -%}
  <div class="gg-banner__utility">
    {%- if s.logo_text != blank -%}
      <span class="gg-banner__logo">{{ s.logo_text }}</span>
    {%- endif -%}

    {%- if s.topbar_text != blank -%}
      <p class="gg-banner__tagline">{{ s.topbar_text }}</p>
    {%- endif -%}

    {%- if s.topbar_button_label != blank -%}
      <a class="gg-btn gg-btn--yellow" href="{{ s.topbar_button_link | default: '#' }}">
        <span>{{ s.topbar_button_label }}</span>
        {{ arrow }}
      </a>
    {%- endif -%}
  </div>

  {%- comment -%} Hero: illustration background with content overlaid on the left. {%- endcomment -%}
  <div class="gg-banner__hero">
    {%- if s.background_image != blank -%}
      <img
        class="gg-banner__illustration"
        src="{{ s.background_image | image_url: width: 2000 }}"
        alt="{{ s.background_image.alt | escape }}"
        width="{{ s.background_image.width }}"
        height="{{ s.background_image.height }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- endif -%}

    <div class="gg-banner__content">
      {%- if s.heading != blank -%}
        <h1 class="gg-banner__heading">{{ s.heading }}</h1>
      {%- endif -%}

      {%- if s.description != blank -%}
        <div class="gg-banner__desc">{{ s.description }}</div>
      {%- endif -%}

      {%- if s.button_label != blank -%}
        <a class="gg-btn gg-btn--dark" href="{{ s.button_link | default: '#' }}">
          <span>{{ s.button_label }}</span>
          {{ arrow }}
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Footer bar: sustainability strip. {%- endcomment -%}
  {%- if s.bottombar_text != blank -%}
    <div class="gg-banner__footer">
      <p>{{ s.bottombar_text }}</p>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Gift Guide Banner",
  "tag": "section",
  "class": "gift-guide-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Utility bar (top)"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "topbar_text",
      "label": "Tagline",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "topbar_button_label",
      "label": "Button label",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "topbar_button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background illustration"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Footer bar (bottom)"
    },
    {
      "type": "text",
      "id": "bottombar_text",
      "label": "Footer text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    }
  ],
  "presets": [
    {
      "name": "Gift Guide Banner"
    }
  ]
}
{% endschema %}

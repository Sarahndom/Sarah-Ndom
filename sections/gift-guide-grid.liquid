{%- comment -%}
  ============================================================================
  Gift Guide — Grid  (custom section, built from scratch)
  ----------------------------------------------------------------------------
  Renders the "Tisso vison in the wild" gallery: up to 6 merchant-selected
  products laid out 3x2. Each cell shows the product's real featured image and
  a "+" trigger that opens the shared product popup.

  Product data (title, price, description, options, variants) is serialised
  once into per-product JSON via the `gift-guide-product-json` snippet, so the
  popup opens instantly with no extra network request.

  The popup markup is included once at the end (shared by all cells).

  SCHEMA NOTES
    - "product" blocks (max 6)  : each holds one product picker.
    - bonus_product setting      : the item auto-added to cart when a chosen
                                   variant is Color=Black AND Size=Medium.
                                   Kept as a setting (not hardcoded) because
                                   variant IDs differ per store / re-import.
  ============================================================================
{%- endcomment -%}

{{ 'gift-guide.css' | asset_url | stylesheet_tag }}

<section
  class="gg-grid"
  data-gift-guide-grid
  {%- if section.settings.bonus_product != blank %}
    data-bonus-product-id="{{ section.settings.bonus_product.id }}"
    data-bonus-variant-id="{{ section.settings.bonus_product.selected_or_first_available_variant.id }}"
  {%- endif %}
  {%- if section.settings.heading != blank %}
    aria-labelledby="gg-grid-heading-{{ section.id }}"
  {%- endif %}
>
  {%- if section.settings.heading != blank -%}
    <h2 class="gg-grid__heading" id="gg-grid-heading-{{ section.id }}">
      {{ section.settings.heading }}
    </h2>
  {%- endif -%}

  <ul class="gg-grid__list" role="list">
    {%- for block in section.blocks -%}
      {%- assign product = block.settings.product -%}
      <li class="gg-grid__item" {{ block.shopify_attributes }}>
        <div class="gg-grid__card">
          {%- if product != blank -%}
            {%- if product.featured_image != blank -%}
              <img
                class="gg-grid__image"
                src="{{ product.featured_image | image_url: width: 900 }}"
                alt="{{ product.featured_image.alt | default: product.title | escape }}"
                width="{{ product.featured_image.width }}"
                height="{{ product.featured_image.height }}"
                loading="lazy"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'gg-grid__image gg-grid__image--placeholder' }}
            {%- endif -%}

            {%- comment -%} Opens the product popup. {%- endcomment -%}
            <button
              type="button"
              class="gg-grid__add"
              data-product-id="{{ product.id }}"
              aria-label="View {{ product.title | escape }}"
            >
              <svg class="gg-grid__add-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </button>

            {%- comment -%} Product data the popup reads on open. {%- endcomment -%}
            {% render 'gift-guide-product-json', product: product %}
          {%- else -%}
            {%- comment -%} Empty slot — shown in the editor until a product is picked. {%- endcomment -%}
            {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'gg-grid__image gg-grid__image--placeholder' }}
          {%- endif -%}
        </div>
      </li>
    {%- endfor -%}
  </ul>

  {%- comment -%} Shared popup, rendered once for all cells. {%- endcomment -%}
  {% render 'gift-guide-popup' %}
</section>

<script src="{{ 'gift-guide.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Gift Guide Grid",
  "tag": "section",
  "class": "gift-guide-grid-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "header",
      "content": "Cart rules"
    },
    {
      "type": "product",
      "id": "bonus_product",
      "label": "Bonus product (auto-add)",
      "info": "Automatically added to the cart when a product is added with Color = Black and Size = Medium."
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gift Guide Grid",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}

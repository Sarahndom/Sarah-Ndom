{%- comment -%}
  ============================================================================
  Gift Guide — Product JSON  (helper, one per grid cell)
  ----------------------------------------------------------------------------
  Serialises a single product into a <script type="application/json"> blob the
  popup reads on open. A curated payload (not the full product object) keeps the
  DOM lean and the JS simple. Everything is dynamic — nothing hardcoded.

  Expects:
    product  - a product object (block.settings.product)

  Options are emitted in position order so JS can match a variant by option
  NAME (index in the array = option position - 1), never by fixed position.

  PHASE STATUS
    [x] Phase 5  payload (this file, current)
  ============================================================================
{%- endcomment -%}

{%- if product != blank -%}
  <script type="application/json" class="gg-product-json" data-product-id="{{ product.id }}">
    {
      "id": {{ product.id | json }},
      "title": {{ product.title | json }},
      "url": {{ product.url | json }},
      "description": {{ product.description | json }},
      "image": {%- if product.featured_image != blank -%}{{ product.featured_image | image_url: width: 600 | json }}{%- else -%}null{%- endif -%},
      "price": {{ product.price | money | json }},
      "options": [
        {%- for option in product.options_with_values -%}
          {
            "name": {{ option.name | json }},
            "position": {{ option.position | json }},
            "values": {{ option.values | json }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ],
      "variants": [
        {%- for variant in product.variants -%}
          {
            "id": {{ variant.id | json }},
            "title": {{ variant.title | json }},
            "available": {{ variant.available | json }},
            "price": {{ variant.price | money | json }},
            "options": {{ variant.options | json }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  </script>
{%- endif -%}
